---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import Footer from '../components/Footer.astro';
import { getT } from '../i18n/ui';

const lang = 'en';
const t = getT(lang);
const l = t.legalPage;
const crumbs = [
  { name: t.breadcrumb.home, href: '/' },
  { name: l.title, href: '/legal/' },
];
---

<Layout lang={lang} title="Legal notice — Kaestria" description="Legal notice for the Kaestria website.">
  <Header lang={lang} t={t} />
  <main class="pt-32 pb-24">
    <article class="max-w-3xl mx-auto px-6 lg:px-8">
      <Breadcrumb items={crumbs} />
      <div class="font-mono text-sm text-accent mb-3">/legal</div>
      <h1 class="text-4xl lg:text-5xl font-bold tracking-tight mb-12">{l.title}</h1>

      <div class="space-y-8 text-text-muted leading-relaxed">
        <section>
          <h2 class="text-xl font-bold text-text mb-3">{l.editorTitle}</h2>
          <p set:html={l.editorIntro('<span class="text-text">EI Arthur Mrowiec</span>', '<span class="text-text">Kaestria</span>')}></p>
          <p class="mt-2">
            11 rue Maurice Lecolier<br />
            97441 Sainte-Suzanne<br />
            Reunion Island, France
          </p>
          <p class="mt-2">
            <span class="text-text-dim">SIRET:</span> 851 571 927 00025
          </p>
          <p class="mt-2">
            <span class="text-text-dim">Email:</span>
            <a href="mailto:contact@kaestria.fr" class="text-accent hover:underline">contact@kaestria.fr</a>
          </p>
          <p class="mt-2">
            <span class="text-text-dim">{l.director}:</span> Arthur Mrowiec
          </p>
        </section>

        <section>
          <h2 class="text-xl font-bold text-text mb-3">{l.hostTitle}</h2>
          <p>
            <span class="text-text">Hostinger International Ltd.</span><br />
            61 Lordou Vironos Street, 6023 Larnaca, Cyprus<br />
            <a href="https://www.hostinger.com" target="_blank" rel="noopener" class="text-accent hover:underline">www.hostinger.com</a>
          </p>
        </section>

        <section>
          <h2 class="text-xl font-bold text-text mb-3">{l.ipTitle}</h2>
          <p>{l.ipBody}</p>
        </section>

        <section>
          <h2 class="text-xl font-bold text-text mb-3">{l.dataTitle}</h2>
          <p>{l.dataBody}</p>
        </section>

        <section>
          <h2 class="text-xl font-bold text-text mb-3">{l.cookiesTitle}</h2>
          <p>{l.cookiesBody}</p>
        </section>

        <section>
          <h2 class="text-xl font-bold text-text mb-3">{l.lawTitle}</h2>
          <p>{l.lawBody}</p>
        </section>
      </div>
    </article>
  </main>
  <Footer lang={lang} t={t} />
</Layout>
