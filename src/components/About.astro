---
import type { UI } from '../i18n/ui';

interface Props {
  t: UI;
}

const { t } = Astro.props;
---

<section id="about" class="py-24 lg:py-32 relative">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16 items-start">
      <div class="lg:col-span-2">
        <div class="font-mono text-sm text-accent mb-3">/about</div>
        <h2 class="text-4xl lg:text-5xl font-bold tracking-tight text-balance">
          {t.about.title}
        </h2>
      </div>

      <div class="lg:col-span-3 space-y-6 text-text-muted text-lg leading-relaxed">
        <p>
          <span class="text-text font-medium">{t.about.p1Role}</span>{t.about.p1Tail}<span class="text-text font-medium">{t.about.p1Years}</span>{t.about.p1End}
        </p>
        <p>
          {t.about.p2Lead}<span class="text-accent font-medium">{t.about.p2Consulting}</span>{t.about.p2Middle}<span class="text-accent font-medium">{t.about.p2Product}</span>{t.about.p2Tail}
        </p>
        <p>{t.about.p3}</p>

        <div class="pt-6 grid grid-cols-3 gap-6 border-t border-white/10">
          <div>
            <div class="text-2xl font-bold text-accent">15+</div>
            <div class="text-xs text-text-dim uppercase tracking-wider mt-1">{t.about.statsYears}</div>
          </div>
          <div>
            <div class="text-2xl font-bold text-accent">5</div>
            <div class="text-xs text-text-dim uppercase tracking-wider mt-1">{t.about.statsProducts}</div>
          </div>
          <div>
            <div class="text-2xl font-bold text-accent">3</div>
            <div class="text-xs text-text-dim uppercase tracking-wider mt-1">{t.about.statsLanguages}</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
