---
import type { UI } from '../i18n/ui';

interface Props {
  t: UI;
}

const { t } = Astro.props;

const icons = ['◉', '◈', '◇', '◐'];
const services = t.services.items.map((s, i) => ({ ...s, icon: icons[i]! }));

const site = 'https://kaestria.fr';
const servicesJsonLd = {
  '@context': 'https://schema.org',
  '@graph': services.map((s, idx) => ({
    '@type': 'Service',
    '@id': `${site}/#service-${idx + 1}`,
    name: s.title,
    description: s.description,
    serviceType: s.title,
    provider: { '@id': `${site}/#kaestria` },
    areaServed: { '@type': 'Place', name: 'Worldwide' },
    availableLanguage: ['English', 'Français', 'Polski'],
    audience: { '@type': 'Audience', audienceType: 'Tech teams, startups, scale-ups, product leaders' },
  })),
};
---

<section id="services" class="py-24 lg:py-32 relative bg-bg-elevated/30">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="mb-16">
      <div class="font-mono text-sm text-accent mb-3">/services</div>
      <h2 class="text-4xl lg:text-5xl font-bold tracking-tight max-w-2xl text-balance">
        {t.services.sectionTitle}
      </h2>
      <p class="mt-4 text-text-muted text-lg max-w-2xl">
        {t.services.sectionSubtitle}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 lg:gap-6">
      {services.map((s) => (
        <article class="group rounded-2xl border border-white/5 bg-bg p-8 hover:border-accent/30 transition-all">
          <div class="text-accent text-2xl mb-4 font-mono">{s.icon}</div>
          <h3 class="text-xl font-bold tracking-tight mb-3">{s.title}</h3>
          <p class="text-text-muted text-sm leading-relaxed">{s.description}</p>
        </article>
      ))}
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(servicesJsonLd)} is:inline />
</section>
