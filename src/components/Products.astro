---
import type { UI } from '../i18n/ui';

interface Props {
  t: UI;
}

const { t } = Astro.props;

// Per-product visual + link metadata, paired by position with t.products.items.
// Suplio keeps its own teal accent; all RankingRider variants share the violet brand.
const RR_ACCENT = 'from-violet-500/25 via-violet-600/10 to-fuchsia-500/5';
const RR_BADGE_LIVE = 'bg-violet-400/20 text-violet-200 border border-violet-400/30';
const RR_BADGE_REVIEW = 'bg-amber-400/20 text-amber-300 border border-amber-400/30';
const RR_BADGE_SOON = 'bg-violet-400/10 text-violet-300 border border-violet-400/20';

const meta = [
  {
    name: 'Suplio',
    accent: 'from-emerald-400/20 to-teal-500/5',
    badgeColor: 'bg-accent text-bg',
    href: 'https://play.google.com/store/apps/details?id=com.scop.suplio',
    span: 'md:col-span-2 md:row-span-2',
    brand: 'suplio' as const,
  },
  {
    name: 'RankingRider Web App',
    accent: RR_ACCENT,
    badgeColor: RR_BADGE_LIVE,
    href: 'https://www.rankingrider.com',
    span: '',
    brand: 'rr' as const,
  },
  {
    name: 'RankingRider Shopify',
    accent: RR_ACCENT,
    badgeColor: RR_BADGE_LIVE,
    href: 'https://apps.shopify.com/rankingrider',
    span: '',
    brand: 'rr' as const,
  },
  {
    name: 'RankingRider Wix',
    accent: RR_ACCENT,
    badgeColor: RR_BADGE_REVIEW,
    href: null,
    span: '',
    brand: 'rr' as const,
  },
  {
    name: 'RankingRider BigCommerce',
    accent: RR_ACCENT,
    badgeColor: RR_BADGE_SOON,
    href: null,
    span: '',
    brand: 'rr' as const,
  },
];

const products = t.products.items.map((item, i) => {
  const m = meta[i]!;
  return {
    ...m,
    tag: item.tag,
    description: item.description,
    badge: t.products.badges[item.badgeKey],
    cta: item.cta,
    ctaInactive: item.ctaInactive,
  };
});
---

<section id="products" class="py-24 lg:py-32 relative">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="mb-16">
      <div class="font-mono text-sm text-accent mb-3">/products</div>
      <h2 class="text-4xl lg:text-5xl font-bold tracking-tight max-w-2xl text-balance">
        {t.products.sectionTitle}
      </h2>
      <p class="mt-4 text-text-muted text-lg max-w-2xl">
        {t.products.sectionSubtitle}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 lg:gap-6">
      {products.map((p) => {
        const linkClass = p.brand === 'rr'
          ? 'inline-flex items-center gap-1 text-sm font-medium text-violet-300 hover:gap-2 transition-all'
          : 'inline-flex items-center gap-1 text-sm font-medium text-accent hover:gap-2 transition-all';
        return (
          <article
            class:list={[
              'group relative rounded-2xl border border-white/5 bg-bg-elevated p-6 lg:p-8 overflow-hidden hover:border-white/15 transition-all',
              p.span,
            ]}
          >
            <div class:list={['absolute inset-0 bg-gradient-to-br opacity-60 pointer-events-none', p.accent]}></div>
            <div class="relative flex flex-col h-full">
              <div class="flex items-start justify-between mb-4 gap-3">
                <div class="flex items-start gap-3 min-w-0">
                  {p.brand === 'rr' && (
                    <span
                      class="shrink-0 mt-0.5 inline-flex items-center justify-center w-9 h-9 rounded-lg bg-violet-500/15 border border-violet-400/25 text-violet-300"
                      aria-hidden="true"
                    >
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/>
                        <path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/>
                        <path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/>
                        <path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/>
                      </svg>
                    </span>
                  )}
                  <div class="min-w-0">
                    <div class="font-mono text-xs text-text-dim mb-1">{p.tag}</div>
                    <h3 class="text-xl lg:text-2xl font-bold tracking-tight truncate">{p.name}</h3>
                  </div>
                </div>
                <span class:list={['shrink-0 text-[10px] font-bold uppercase tracking-wider px-2 py-1 rounded-md', p.badgeColor]}>
                  {p.badge}
                </span>
              </div>
              <p class="text-text-muted text-sm leading-relaxed flex-1">{p.description}</p>
              <div class="mt-6">
                {p.href ? (
                  <a href={p.href} target="_blank" rel="noopener" class={linkClass}>
                    {p.cta} <span aria-hidden="true">→</span>
                  </a>
                ) : (
                  <span class="text-sm text-text-dim italic">{p.ctaInactive}</span>
                )}
              </div>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>
