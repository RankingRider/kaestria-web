---
import type { UI } from '../i18n/ui';

interface Props {
  t: UI;
  homeHref: string;
}

const { t, homeHref } = Astro.props;
---

<section class="relative pt-32 pb-24 lg:pt-40 lg:pb-32 overflow-hidden">
  <div class="absolute inset-0 grid-pattern pointer-events-none"></div>
  <div
    class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[800px] rounded-full pointer-events-none"
    style="background: radial-gradient(circle, rgba(45,212,191,0.12) 0%, transparent 60%);"
  >
  </div>

  <div class="relative max-w-7xl mx-auto px-6 lg:px-8">
    <div class="max-w-4xl">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-white/10 bg-white/5 text-xs font-medium text-text-muted mb-8">
        <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span>
        {t.hero.badge}
      </div>

      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold tracking-tighter leading-[1.05] text-balance">
        {t.hero.titleLine1}
        <span class="block gradient-accent">{t.hero.titleLine2}</span>
      </h1>

      <p class="mt-8 text-lg lg:text-xl text-text-muted max-w-2xl text-balance leading-relaxed">
        {t.hero.descIntro} <span class="text-text font-medium whitespace-nowrap">Arthur Mrowiec</span>{t.hero.descRest}
      </p>

      <p class="mt-6 font-mono text-sm text-accent/80 tracking-tight">
        {t.hero.signature}
      </p>

      <div class="mt-12 flex flex-wrap gap-4">
        <a
          href="mailto:contact@kaestria.fr"
          class="px-6 py-3 rounded-xl bg-accent text-bg font-semibold hover:bg-accent-dim transition-all glow-accent"
        >
          {t.hero.ctaPrimary}
        </a>
        <a
          href={`${homeHref}#products`}
          class="px-6 py-3 rounded-xl border border-white/10 hover:border-white/20 hover:bg-white/5 transition-all"
        >
          {t.hero.ctaSecondary}
        </a>
      </div>
    </div>
  </div>
</section>
